def merge_count(arr, left, mid, right):
    i = left
    j = mid + 1
    temp = []
    inv_count = 0
    while i <= mid and j <= right:
        if arr[i] <= arr[j]:
            temp.append(arr[i])
            i += 1
        else:
            temp.append(arr[j])
            inv_count += (mid - i + 1)
            j += 1
    while i <= mid:
        temp.append(arr[i])
        i += 1
    while j <= right:
        temp.append(arr[j])
        j += 1
    for k in range(left, right + 1):
        arr[k] = temp[k - left]
    return inv_count
def merge_sort_count(arr, left, right):
    inv_count = 0
    if left < right:
        mid = (left + right) // 2
        inv_count += merge_sort_count(arr, left, mid)
        inv_count += merge_sort_count(arr, mid + 1, right)
        inv_count += merge_count(arr, left, mid, right)
    return inv_count
arr = list(map(int, input("Enter elements separated by space: ").split()))
result = merge_sort_count(arr, 0, len(arr) - 1)
print("Number of inversions:", result)





